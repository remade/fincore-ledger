# Ledger Configuration
# Copy this file to .env and adjust values for your environment.
# All values shown are defaults.
#
# Priority order: CLI flags > environment variables > .env file > defaults

# PostgreSQL connection string (required)
LEDGER_POSTGRES_DSN=postgres://ledger:ledger@localhost:5432/ledger?sslmode=disable

# Redis connection URL (required)
LEDGER_REDIS_URL=redis://localhost:6379/0

# gRPC server port
LEDGER_GRPC_PORT=9090

# HTTP server port (health checks)
LEDGER_HTTP_PORT=8080

# OpenTelemetry collector endpoint (leave empty to disable)
LEDGER_OTEL_ENDPOINT=
LEDGER_OTEL_INSECURE=true

# Runtime environment: development, production, test
LEDGER_ENVIRONMENT=development

# Log level: debug, info, warn, error
LEDGER_LOG_LEVEL=info

# Worker intervals (Go duration format: 5s, 30s, 1m, etc.)
LEDGER_WORKER_BATCH_CLOSE_INTERVAL=5s
LEDGER_WORKER_CHECKPOINT_INTERVAL=30s
LEDGER_WORKER_HOLD_EXPIRY_INTERVAL=30s
LEDGER_WORKER_APPROVAL_EXPIRY_INTERVAL=60s
